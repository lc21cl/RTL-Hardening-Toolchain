###############################################################################
# ch5_print_data_timing_pipeline.xdc
# Xilinx XDC Timing Constraints for ch-5 print_data Channel (Pipeline 版本)
#
# 目标 FPGA : Xilinx 7-series (Artix-7 / Kintex-7)
# 工具      : Vivado 2023+
# 时钟      : 10 MHz (100 ns period)
# 时钟域    : Single clock domain (clk)
#
# Pipeline 版本差异:
#   - voted 信号现在通过寄存器输出 (不再是组合输出)
#   - 组合路径从 2 级 LUT 降为 1 级 LUT + FF
#   - 毛刺被 FF 完全抑制
#   - 移除 input_delay / output_delay (核心内部信号, 不在顶层端口)
#
# 时序裕量估算:
#   LUT3 延迟     : ~0.3 ns
#   FF clk-to-Q   : ~1.2 ns
#   布线延迟      : ~0.5 ns
#   建立时间      : 100 - (0.3 + 1.2 + 0.5) = 98 ns 裕量
###############################################################################

# ---------------------------------------------------------------------------
# 1. 主时钟约束 (保持不变)
# ---------------------------------------------------------------------------
create_clock -period 100.000 -name clk [get_ports clk]

# 时钟不确定性 (setup: 0.5 ns, hold: 0.3 ns, 保持不变)
set_clock_uncertainty -setup 0.500 [get_clocks clk]
set_clock_uncertainty -hold  0.300 [get_clocks clk]

# ---------------------------------------------------------------------------
# 2. Input Delay 约束 (已移除)
#    核心内部信号, 不在顶层端口, 无需 set_input_delay。
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 3. Output Delay 约束 (已移除)
#    voted 信号现在寄存器输出, 不再是组合输出,
#    时序由寄存器到寄存器的路径自动分析。
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 4. 寄存器时序裕量估算
#    时钟周期 100 ns, 减去 LUT3 延迟、FF clk-to-Q、布线延迟后,
#    建立时间裕量约为 98 ns。
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 5. Max Delay 约束
#    从 core 输入到 voted 输出 (经过 LUT3 + 寄存器):
#    LUT3 ~0.3ns + 寄存器 ~0.5ns + 布线 ~0.5ns = ~1.3ns
#    设置为 2ns 留有余量。
# ---------------------------------------------------------------------------
set_max_delay -from [get_ports {core1_print_data[*] core2_print_data[*] core3_print_data[*]}] \
              -to   [get_pins -of_objects [get_cells -hierarchical -filter {NAME =~ *gen_pipeline* && REF_NAME =~ *FDRE*}] && {get_pins D}] 2.000

# ---------------------------------------------------------------------------
# 6. Min Delay 约束
#    确保寄存器保持时间满足要求。
# ---------------------------------------------------------------------------
set_min_delay -from [get_pins -of_objects [get_cells -hierarchical -filter {REF_NAME =~ LUT3*}]] \
              -to   [get_pins -of_objects [get_cells -hierarchical -filter {NAME =~ *gen_pipeline* && REF_NAME =~ *FDRE*}] && {get_pins D}] 0.300

# ---------------------------------------------------------------------------
# 7. 寄存器时钟引脚分组约束
#    将所有 pipeline 输出寄存器分为一组, 便于时序报告聚焦。
# ---------------------------------------------------------------------------
group_path -name pipeline_output_regs \
    -to [get_pins -of_objects [get_cells -hierarchical -filter {NAME =~ *gen_pipeline* && REF_NAME =~ *FDRE*}] && {get_pins D}]

###############################################################################
# End of ch5_print_data_timing_pipeline.xdc
###############################################################################
